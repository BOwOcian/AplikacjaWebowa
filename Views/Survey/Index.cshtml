@model IEnumerable<SurveyApp.Models.Survey>
@{
    ViewData["Title"] = "Lista Ankiet";
}

<h2>Dostępne ankiety</h2>

<table class="table table-striped mt-4">
    <thead>
        <tr>
            <th>Tytuł</th>
            <th>Opis</th>
            <th>Data utworzenia</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="4" class="text-center text-muted">Brak ankiet w systemie.</td>
            </tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.CreatedAt.ToString("dd.MM.yyyy")</td>
                    <td>
                        <a asp-action="Vote" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Głosuj</a>
                        <a asp-action="Results" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Zobacz wyniki</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>